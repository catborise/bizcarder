# System Configuration
ENCRYPTION_KEY=replace_with_32_character_secret_key
SESSION_SECRET=replace_with_strong_session_secret

# Database Configuration
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm_db
DB_HOST=db
DB_PORT=5432

# Backend Configuration
PORT=5000
SESSION_SECURE=false

# SAML Configuration
SAML_ENTRY_POINT=https://identity.provider.com/sso
SAML_ISSUER=bizcarder
SAML_CALLBACK_URL=http://localhost:5000/auth/login/callback
SAML_CERT=PASTE_IDP_CERTIFICATE_HERE
SAML_LOGOUT_URL=https://identity.provider.com/slo
SAML_ALLOWED_ORG_UNITS="ou=it,dc=example,dc=com"

# URLs
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Resource Limits
DB_MEMORY_LIMIT=512M
BACKEND_MEMORY_LIMIT=1G
FRONTEND_MEMORY_LIMIT=2G
FRONTEND_NODE_MAX_MEM=2048
