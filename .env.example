# System Configuration
NODE_ENV=development
ENCRYPTION_KEY=replace_with_32_character_secret_key
SESSION_SECRET=replace_with_strong_session_secret_min_32_chars
CRM_API_ENCRYPTION_KEY=replace_with_32_char_encryption_key

# Database Configuration
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm_db
DB_HOST=db
DB_PORT=5432

# Backend Configuration
PORT=5000
ADMIN_DEFAULT_PASSWORD=Admin123!
SESSION_SECURE=false

# SAML Configuration
SAML_ENTRY_POINT=https://identity.provider.com/sso
SAML_ISSUER=bizcarder
SAML_CALLBACK_URL=http://localhost:5000/auth/login/callback
SAML_CERT=PASTE_IDP_CERTIFICATE_HERE
SAML_LOGOUT_URL=https://identity.provider.com/slo
SAML_ALLOWED_ORG_UNITS="ou=it,dc=example,dc=com"

# URLs
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production domain (used by Caddy for auto HTTPS)
DOMAIN=localhost

# Redis (required for multi-instance rate limiting)
# Leave empty or remove to use in-memory rate limiting (single instance only)
REDIS_URL=redis://redis:6379

# Database Connection Pool (per instance)
DB_POOL_MIN=2
DB_POOL_MAX=10

# Resource Limits
DB_MEMORY_LIMIT=512M
BACKEND_MEMORY_LIMIT=1G
FRONTEND_MEMORY_LIMIT=2G
FRONTEND_NODE_MAX_MEM=2048
REDIS_MEMORY_LIMIT=128M

# Email Notifications (optional — leave empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
