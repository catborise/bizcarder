# Multi-stage: build frontend, serve everything via Caddy
# Used by: docker compose --profile prod (see docker-compose.yml)

# ── Stage 1: Build frontend ─────────────────────────────
FROM node:22-alpine AS frontend
WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ .
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
RUN npm run build

# ── Stage 2: Caddy serves static files + reverse proxies API ──
FROM caddy:2-alpine
COPY --from=frontend /app/dist /srv
EXPOSE 80 443
