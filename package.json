{
    "name": "bizcarder",
    "private": true,
    "description": "Bizcarder CRM — monorepo tooling",
    "scripts": {
        "lint": "cd frontend && npm run lint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "frontend/src/**/*.{js,jsx}": [
            "prettier --write",
            "eslint --fix --max-warnings 0"
        ],
        "backend/**/*.js": [
            "prettier --write"
        ],
        "*.{json,md,css}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.1.0",
        "prettier": "^3.8.2"
    }
}
