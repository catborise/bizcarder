{
    "name": "crm-backend",
    "version": "1.0.0",
    "description": "CRM Backend API",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "check-db": "node check_db.js",
        "db:migrate": "npx sequelize-cli db:migrate",
        "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
        "db:seed": "npx sequelize-cli db:seed:all",
        "test": "jest --coverage --forceExit --detectOpenHandles",
        "test:watch": "jest --watch"
    },
    "dependencies": {
        "@node-saml/passport-saml": "^5.1.0",
        "axios": "^1.14.0",
        "bcryptjs": "^2.4.3",
        "connect-flash": "^0.1.1",
        "connect-session-sequelize": "^7.1.5",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^16.3.1",
        "exceljs": "^4.4.0",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "express-session": "^1.19.0",
        "express-validator": "^7.3.2",
        "helmet": "^7.1.0",
        "morgan": "^1.10.1",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^8.0.4",
        "passport": "^0.7.0",
        "passport-local": "^1.0.0",
        "pdfkit-table": "^0.1.99",
        "pg": "^8.20.0",
        "pg-hstore": "^2.3.4",
        "qrcode": "^1.5.4",
        "rate-limit-redis": "^4.3.1",
        "redis": "^5.11.0",
        "sequelize": "^6.37.8",
        "speakeasy": "^2.0.0",
        "vcf": "^2.1.2",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "jest": "^30.3.0",
        "nodemon": "^3.1.14",
        "sequelize-cli": "^6.6.5",
        "supertest": "^7.2.2"
    }
}
