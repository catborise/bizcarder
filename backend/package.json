        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "express-session": "^1.17.3",
        "multer": "^1.4.5-lts.1",
        "passport": "^0.7.0",
        "passport-local": "^1.0.0",
        "pdfkit-table": "^0.1.99",
