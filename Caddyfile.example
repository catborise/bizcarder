{domain.com} {
    # 1. API İstekleri (Backend'e gider)
    handle /auth/* {
        reverse_proxy backend:5000
    }
    handle /api/* {
        reverse_proxy backend:5000
    }
    handle /uploads/* {
        reverse_proxy backend:5000
    }

    # 2. Geri kalan her şey (Frontend'e gider)
    handle {
        reverse_proxy frontend:80
    }

    log {
        output file /data/access.log
    }
}
